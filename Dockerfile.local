FROM openclaw:local

################################################################
# Dockerfile.local — custom layer on top of openclaw:local
# Adds all deployment-specific tools, skills, and patches.
# Build: docker build -t openclaw:local -f Dockerfile.local .
# 02/2026 Created: HighDesertHacker - https://github.com/highdeserthacker
################################################################
USER root

################################################################
# System packages and build tools
################################################################
# apt packages are defined here. Customize as needed.
# build-essential/procps/file: required for Linuxbrew to bootstrap itself at
# runtime (brew compiles from source when no bottle is available).
# Python
# Go language: golang-go from apt (Debian bookworm) may be older; upgrade if go-based
# skills require a newer version.
# mosquitto-clients: for mqtt access
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      jq ripgrep ffmpeg python3 python3-pip mosquitto-clients \
      build-essential procps file golang-go && \
    apt-get clean && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*


################################################################
# Runtimes
# Note: npm/node are already present in the base image (node:22-bookworm).
################################################################
# --- uv (uv-based skills, e.g. nano-pdf) ---
RUN pip3 install --break-system-packages uv

# --- Homebrew / Linuxbrew (brew-based skills) ---
# brew is NOT installed here. Instead, a bind mount in docker-compose.override.yml
# maps ${OPENCLAW_CONFIG_DIR}/linuxbrew → /home/linuxbrew on the host.
# On first brew skill install, the skill manager bootstraps brew into that
# bind-mounted path. Subsequent container starts find it already there.
# ENV vars below ensure brew is on PATH and recognised once it self-installs.
RUN mkdir -p /home/linuxbrew && chown -R node:node /home/linuxbrew
ENV PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:${PATH}"
ENV HOMEBREW_PREFIX=/home/linuxbrew/.linuxbrew
ENV HOMEBREW_BREW_FILE=/home/linuxbrew/.linuxbrew/bin/brew

################################################################
# Install User specified skills
################################################################

################
# Apt Installs

# GitHub CLI (github skill)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
  | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
  > /etc/apt/sources.list.d/github-cli.list \
  && apt-get update && apt-get install -y gh && rm -rf /var/lib/apt/lists/*

################  
# Binary downloads (curl+tar)

# gog (Google Workspace skill)
RUN GOG_URL=$(curl -sf https://api.github.com/repos/steipete/gogcli/releases/latest \
  | jq -r '.assets[] | select(.name | contains("linux_amd64")) | .browser_download_url') \
  && [ -n "$GOG_URL" ] || { echo "ERROR: could not resolve gog download URL"; exit 1; } \
  && curl -fL "$GOG_URL" | tar -xz -C /usr/local/bin \
  && chmod +x /usr/local/bin/gog

# goplaces (goplaces skill)
RUN GOPLACES_URL=$(curl -sf https://api.github.com/repos/steipete/goplaces/releases/latest \
  | jq -r '.assets[] | select(.name | contains("linux_amd64")) | .browser_download_url') \
  && [ -n "$GOPLACES_URL" ] || { echo "ERROR: could not resolve goplaces download URL (rate limit or no linux_amd64 release?)"; exit 1; } \
  && curl -fL "$GOPLACES_URL" | tar -xz -C /usr/local/bin \
  && chmod +x /usr/local/bin/goplaces

# camsnap (camsnap skill)
RUN CAMSNAP_URL=$(curl -sf https://api.github.com/repos/steipete/camsnap/releases/latest \
  | jq -r '.assets[] | select(.name | contains("linux_amd64")) | .browser_download_url') \
  && [ -n "$CAMSNAP_URL" ] || { echo "ERROR: could not resolve camsnap download URL (rate limit or no linux_amd64 release?)"; exit 1; } \
  && curl -fL "$CAMSNAP_URL" | tar -xz -C /usr/local/bin \
  && chmod +x /usr/local/bin/camsnap

################
# Google Chrome (browser tool)
# Install via direct .deb per https://docs.openclaw.ai/tools/browser-linux-troubleshooting
RUN wget -q https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb \
  && apt-get update \
  && (dpkg -i google-chrome-stable_current_amd64.deb || apt-get install -fy --no-install-recommends) \
  && rm google-chrome-stable_current_amd64.deb \
  && rm -rf /var/lib/apt/lists/*

################
# Python downloads (pip)
# --- openai-whisper (openai-whisper skill) ---
# CPU-only torch to avoid pulling in the ~2GB CUDA build by default
RUN pip3 install --break-system-packages torch --index-url https://download.pytorch.org/whl/cpu \
  && pip3 install --break-system-packages openai-whisper

# Pre-download tiny model; symlink into node user cache path.
# Whisper always looks in ~/.cache/whisper — no env var override exists.
RUN python3 -c "import whisper; whisper.load_model('tiny', download_root='/usr/share/whisper-models')" \
  && mkdir -p /home/node/.cache \
  && ln -s /usr/share/whisper-models /home/node/.cache/whisper \
  && chown node:node /home/node/.cache

# Pre-create ~/.config with node ownership so Docker bind mounts (e.g. gogcli)
# don't create it as root, which would prevent Chrome from writing there.
RUN mkdir -p /home/node/.config && chown node:node /home/node/.config



################################################################
# Runtime skill install persistence
################################################################
# Route browser-console skill installs into bind-mounted paths so they survive
# container restarts without extra compose volumes.
# brew kind  → /home/linuxbrew bind mount (see docker-compose.override.yml)
# download   → ~/.openclaw/tools/ (already mounted)
# npm/uv/go  → ~/.openclaw/ subdirs via env vars below
ENV NPM_CONFIG_PREFIX=/home/node/.openclaw/npm
ENV UV_TOOL_BIN_DIR=/home/node/.openclaw/uv/bin
ENV GOBIN=/home/node/.openclaw/go/bin
ENV PATH="/home/node/.openclaw/npm/bin:/home/node/.openclaw/uv/bin:/home/node/.openclaw/go/bin:${PATH}"

USER node
